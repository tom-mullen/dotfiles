#!/usr/bin/env zsh
# Standalone dotfiles sync script for manual, tat, and hourly use

set -e

DOTFILES_DIR="$HOME/dotfiles"
LOG_FILE="$HOME/Library/Logs/dotfiles-sync.log"

log() { echo "[$(date)] $1" >> "$LOG_FILE" }

# Ensure we have the correct PATH for Homebrew and Git
export PATH="/opt/homebrew/bin:/usr/local/bin:/usr/bin:/bin:/usr/sbin:/sbin:$PATH"

log "Starting sync..."

cd "$DOTFILES_DIR" || exit 1

# 1. Update Brewfile
log "Updating Brewfile..."
brew bundle dump --force

# 2. Stash local changes before pulling
git stash --quiet

# 3. Pull latest changes, abort rebase on failure
log "Pulling changes..."
if ! git pull --rebase --quiet; then
    log "ERROR: Rebase failed. Aborting rebase and restoring stash."
    git rebase --abort
    git stash pop --quiet 2>/dev/null
    exit 1
fi

# 4. Restore stashed changes
git stash pop --quiet 2>/dev/null || true

# 5. Commit and push if there are changes
if [[ -n $(git status --porcelain) ]]; then
    log "Changes detected. Pushing..."
    git add -A
    git commit -m "chore: auto-sync [$(date +'%Y-%m-%d %H:%M:%S')]" --quiet
    git push --quiet
    log "Sync complete."
else
    log "No changes to sync."
fi
