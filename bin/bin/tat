#!/usr/bin/env zsh
#
# Attach or create tmux session named the same as current directory.

# Source automation functions if they exist
[[ -f ~/dotfiles/zsh/configs/automation.zsh ]] && source ~/dotfiles/zsh/configs/automation.zsh

path_name="$(basename "$PWD" | tr . -)"
session_name=${1-$path_name}

not_in_tmux() {
  [ -z "$TMUX" ]
}

session_exists() {
  tmux has-session -t "=$session_name"
}

create_detached_session() {
  (TMUX='' tmux new-session -Ad -s "$session_name")
}

sync_and_check() {
  # 1. Sync dotfiles (pull latest + brew bundle dump + push any local changes)
  sync_dotfiles
  
  # 2. Check current project sync status (for non-dotfile repos)
  if [[ "$PWD" != "$HOME/dotfiles" ]]; then
    check_git_sync
  fi
}

create_if_needed_and_attach() {
  if not_in_tmux; then
    sync_and_check
    tmux new-session -As "$session_name"
  else
    if ! session_exists; then
      create_detached_session
    fi
    tmux switch-client -t "$session_name"
  fi
}

create_if_needed_and_attach
